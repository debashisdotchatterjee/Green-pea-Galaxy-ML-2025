# ============================================================
# Advanced dataset visualization for Green Pea galaxies
# Creates:
#   1) 3D observational-physical overview
#   2) 3D PCA embedding overview
# Saves figures for direct LaTeX use
# ============================================================

import os
import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
from matplotlib.colors import Normalize
from matplotlib import cm
from mpl_toolkits.mplot3d import Axes3D
from sklearn.preprocessing import StandardScaler
from sklearn.decomposition import PCA

# ----------------------------
# Input/output paths
# ----------------------------
DATA_PATH = "/content/peas_tbl4.csv"   # change if needed
OUTDIR = "/content/green_pea_dataset_figures"
os.makedirs(OUTDIR, exist_ok=True)

# ----------------------------
# Load data
# ----------------------------
df_raw = pd.read_csv(DATA_PATH)

# ----------------------------
# Clean column names
# ----------------------------
df_raw.columns = [c.strip().replace("# ", "").strip() for c in df_raw.columns]

# Expected columns
expected = [
    "DR7OBJID", "RA", "DEC", "REDSHIFT", "OIII_EW",
    "L_FUV", "L_FUV_ERR", "SFR", "SFR_ERR",
    "METALLICITY", "METALLICITY_ERR_UPPER",
    "METALLICITY_ERR_LOWER", "M_STELLAR"
]

# Keep only available columns
cols_available = [c for c in expected if c in df_raw.columns]
df = df_raw[cols_available].copy()

# Convert numeric columns
for c in cols_available:
    df[c] = pd.to_numeric(df[c], errors="coerce")

# ----------------------------
# Construct transformed variables
# ----------------------------
df["LOG_OIII_EW"] = np.log10(1 + df["OIII_EW"])
df["LOG_SFR"] = np.log10(1 + df["SFR"])
df["LOG_L_FUV"] = np.log10(1 + df["L_FUV"])

# Here M_STELLAR is already on a log scale in the catalogue
df["MSTAR_LOG"] = df["M_STELLAR"]

# Convert metallicity confidence limits to uncertainty widths
df["Y_TARGET"] = df["METALLICITY"]
df["YERR_UP"] = df["METALLICITY_ERR_UPPER"] - df["METALLICITY"]
df["YERR_LOW"] = df["METALLICITY"] - df["METALLICITY_ERR_LOWER"]
df["YERR_SYM"] = 0.5 * (df["YERR_UP"] + df["YERR_LOW"])

# ----------------------------
# Main modelling subset for overview figure
# ----------------------------
main_cols = ["MSTAR_LOG", "LOG_SFR", "LOG_OIII_EW", "REDSHIFT", "Y_TARGET"]
plot_df = df[main_cols].dropna().copy()

print("Shape for main 3D figure:", plot_df.shape)

# ----------------------------
# Helper for marker sizes
# ----------------------------
zmin, zmax = plot_df["REDSHIFT"].min(), plot_df["REDSHIFT"].max()
if zmax > zmin:
    sizes = 40 + 220 * (plot_df["REDSHIFT"] - zmin) / (zmax - zmin)
else:
    sizes = np.repeat(100, len(plot_df))

# ----------------------------
# Figure 1: 3D observational-physical overview
# ----------------------------
fig = plt.figure(figsize=(10.5, 8.5))
ax = fig.add_subplot(111, projection="3d")

norm = Normalize(vmin=plot_df["Y_TARGET"].min(), vmax=plot_df["Y_TARGET"].max())
cmap = cm.viridis
colors = cmap(norm(plot_df["Y_TARGET"].values))

sc = ax.scatter(
    plot_df["MSTAR_LOG"],
    plot_df["LOG_SFR"],
    plot_df["LOG_OIII_EW"],
    c=plot_df["Y_TARGET"],
    cmap="viridis",
    s=sizes,
    alpha=0.88,
    edgecolor="black",
    linewidth=0.4
)

ax.set_xlabel(r"Stellar mass, $\log(M_\ast/M_\odot)$", labelpad=10, fontsize=11)
ax.set_ylabel(r"$\log_{10}(1+\mathrm{SFR})$", labelpad=10, fontsize=11)
ax.set_zlabel(r"$\log_{10}(1+\mathrm{EW}_{[\mathrm{O\,III}]})$", labelpad=12, fontsize=11)

ax.set_title(
    "Green Pea galaxies: 3D overview of the main observed attributes",
    fontsize=13,
    pad=16
)

# View angle
ax.view_init(elev=24, azim=132)

# Colorbar
cbar = fig.colorbar(sc, ax=ax, pad=0.08, shrink=0.78)
cbar.set_label(r"Adopted metallicity, $12+\log(\mathrm{O/H})$", fontsize=11)

# Add a mini legend for redshift marker sizes
for rz, s in zip(
    np.quantile(plot_df["REDSHIFT"], [0.2, 0.5, 0.8]),
    np.quantile(sizes, [0.2, 0.5, 0.8])
):
    ax.scatter([], [], [], s=s, c="gray", alpha=0.6, edgecolor="black",
               label=fr"$z \approx {rz:.2f}$")
ax.legend(loc="upper left", bbox_to_anchor=(0.02, 0.98), frameon=True, fontsize=9)

plt.tight_layout()
fig1_path = os.path.join(OUTDIR, "dataset_3d_overview.png")
plt.savefig(fig1_path, dpi=400, bbox_inches="tight")
plt.show()

print("Saved:", fig1_path)

# ----------------------------
# Figure 2: 3D PCA embedding (optional but attractive)
# ----------------------------
pca_cols = ["REDSHIFT", "LOG_OIII_EW", "LOG_SFR", "LOG_L_FUV", "MSTAR_LOG", "Y_TARGET"]
pca_df = df[pca_cols].dropna().copy()

print("Shape for PCA figure:", pca_df.shape)

X = pca_df[["REDSHIFT", "LOG_OIII_EW", "LOG_SFR", "LOG_L_FUV", "MSTAR_LOG"]].values
y = pca_df["Y_TARGET"].values

X_scaled = StandardScaler().fit_transform(X)
pca = PCA(n_components=3, random_state=42)
X_pca = pca.fit_transform(X_scaled)

fig = plt.figure(figsize=(10.5, 8.5))
ax = fig.add_subplot(111, projection="3d")

sc2 = ax.scatter(
    X_pca[:, 0], X_pca[:, 1], X_pca[:, 2],
    c=y,
    cmap="plasma",
    s=85,
    alpha=0.90,
    edgecolor="black",
    linewidth=0.35
)

ax.set_xlabel(f"PC1 ({100*pca.explained_variance_ratio_[0]:.1f}%)", labelpad=10, fontsize=11)
ax.set_ylabel(f"PC2 ({100*pca.explained_variance_ratio_[1]:.1f}%)", labelpad=10, fontsize=11)
ax.set_zlabel(f"PC3 ({100*pca.explained_variance_ratio_[2]:.1f}%)", labelpad=12, fontsize=11)

ax.set_title(
    "Green Pea galaxies: 3D PCA embedding of the predictor space",
    fontsize=13,
    pad=16
)

ax.view_init(elev=26, azim=135)

cbar2 = fig.colorbar(sc2, ax=ax, pad=0.08, shrink=0.78)
cbar2.set_label(r"Adopted metallicity, $12+\log(\mathrm{O/H})$", fontsize=11)

plt.tight_layout()
fig2_path = os.path.join(OUTDIR, "dataset_3d_pca.png")
plt.savefig(fig2_path, dpi=400, bbox_inches="tight")
plt.show()

print("Saved:", fig2_path)

# ----------------------------
# Optional: print explained variance
# ----------------------------
print("\nExplained variance ratios:")
for i, v in enumerate(pca.explained_variance_ratio_, start=1):
    print(f"PC{i}: {100*v:.2f}%")
print(f"Total (PC1+PC2+PC3): {100*np.sum(pca.explained_variance_ratio_):.2f}%")
